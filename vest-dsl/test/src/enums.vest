a_closed_enum = enum {
  A = 0,
  B = 1,
  C = 2,
}

a_regular_choose(@e: a_closed_enum) = choose(@e) {
  A => u8,
  B => u16,
  C => u32,
}


an_open_enum = enum {
  A = 0,
  B = 1,
  C = 2,
  ...
}

a_choose_with_default(@e: an_open_enum) = choose(@e) {
  A => u8,
  B => u16,
  C => u32,
  _ => Tail,
}

a_non_dependent_choose = choose {
  Variant1(u8 | 0..10),
  Variant2(u8 | 11..20),
  Variant3(u8 | 21..),
}

a_typed_closed_enum = enum {
  X = 0u16,
  Y = 1,
  Z = 2,
}

a_typed_choose(@e: a_typed_closed_enum) = choose(@e) {
  X => u8,
  Y => u16,
  Z => u32,
}

a_typed_open_enum = enum {
  P = 0x00u32,
  Q = 0x01u32,
  R = 0x02u32,
  ...
}

a_typed_choose_with_default(@e: a_typed_open_enum) = choose(@e) {
  P => u8,
  Q => u16,
  R => u32,
  _ => Tail,
}

// enums with mixed typed and untyped integer literals (all suffixed ones must agree)
a_mixed_typed_enum = enum {
  M = 0u8,
  N = 1,
  O = 2u8,
}
