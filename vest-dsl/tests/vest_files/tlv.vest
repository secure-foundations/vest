msg1 = [u8; 32]

Header = {
    const magic: u16 = 0xCAFE,
    version: u8,
    flags: u8,
}

Record = {
    id: u32,
    value: u32,
}

RefinedPacket = {
    header: Header,
    @payload_len: u16 | 8..10000,
    payload: [u8; @payload_len] >>= Vec<Record>,
}

msg2 = RefinedPacket
msg3 = {
  x: u16,
  y: u16,
}

msg_ty = enum {
  Ty1 = 1u8,
  Ty2 = 2,
  Ty3 = 3,
}

msg = {
  @tag: msg_ty,
  @len: u16 | 0..8000,
  val: [u8; @len] >>=
    choose (@tag) {
      Ty1 => msg1,
      Ty2 => msg2,
      Ty3 => msg3,
  },
}
